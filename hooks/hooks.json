{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/bin/design.mjs\" status --json"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/bin/design.mjs\" health $(echo \"$CLAUDE_TOOL_PATH\" | sed 's|.*projects/\\([^/]*\\)/.*|\\1|') --json"
          }
        ]
      }
    ]
  }
}
